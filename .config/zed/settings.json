{
  "theme": "One Light",

  "ui_font_family": "Source Sans 3", // https://github.com/zed-industries/zed/issues/22676
  "ui_font_fallbacks": ["Source Han Sans"], // https://github.com/zed-industries/zed/issues/22676
  "ui_font_size": 16,
  "buffer_font_family": "Iosevka Term", // https://github.com/zed-industries/zed/issues/22676
  "buffer_font_fallbacks": ["Source Han Sans"], // https://github.com/zed-industries/zed/issues/22676
  "buffer_font_size": 14,

  "sticky_scroll": {
    "enabled": true,
  },

  "vim_mode": true,
  "semantic_tokens": "combined",
  "use_smartcase_search": true,

  "autosave": "on_focus_change",
  "code_actions_on_format": {
    "source.fixAll": true,
    "source.organizeImports": true,
  },
}
