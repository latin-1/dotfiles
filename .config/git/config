[user]
	name = Hikari Hayashi
	email = rev.hikari@gmail.com
[core]
	pager = "if command -v delta &>/dev/null; then delta; else less; fi"
[init]
	defaultBranch = main
[diff]
	algorithm = histogram
	colorMoved = dimmed-zebra
[merge]
	conflictStyle = zdiff3
[rebase]
	autoSquash = true
[pull]
	ff = only
[push]
	autoSetupRemote = true
[delta]
	features = catppuccin-latte
	line-numbers = true
[include]
	path = ~/.local/share/dotfiles/repos/catppuccin-delta/catppuccin.gitconfig
	path = ./private.gitconfig
